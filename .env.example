# 复制为 .env 后填值（本地调试用；GitHub 上填到 Settings -> Secrets）
# 雪球大V用户ID（主页 u/ 后面那串数字），多个用逗号分隔
XUEQIU_USER_IDS=6515752937,1821992043

# 三级后端（均原生多模态，图文通吃），按顺序尝试：
# 1) Agnes AI agnes-2.0-flash（免费多模态，复用 douban-tracker 配置）
# 2) NVIDIA Qwen3.5-122B-A10B（免费，原生VLM，10B激活，比397B更快）
# 3) 商汤日日新 SenseNova 6.7 Flash-Lite（免费，Token Plan 限时免费）
# 只需填下面三个 Key；模型ID有默认值，一般不用改。
NVIDIA_API_KEY=        # nvapi-...  （供第2后端 Qwen 使用）
AGNES_API_KEY=         # sk-...    （第1后端 Agnes AI）
SENSENOVA_API_KEY=     # sk-...    （第3后端 SenseNova 兜底，Token Plan 限时免费）

# 可选覆盖（一般不用改，默认值已配置好）
# PRIMARY_MODEL=qwen/qwen3.5-122b-a10b
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_MODEL=agnes-2.0-flash
# SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
# SENSENOVA_MODEL=sensenova-6.7-flash-lite
# 超时（秒）：免费档建议 NVIDIA >=120，Agnes 120，SenseNova 120
# PRIMARY_TIMEOUT=120
# AGNES_TIMEOUT=120
# SENSENOVA_TIMEOUT=120
PAGES=2
HEADLESS=true
