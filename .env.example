# 复制为 .env 后填值（本地调试用；GitHub 上填到 Settings -> Secrets）
# 雪球大V用户ID（主页 u/ 后面那串数字），多个用逗号分隔
XUEQIU_USER_IDS=6515752937,1821992043

# 三级后端（均原生多模态，图文通吃），按顺序尝试：
# 1) NVIDIA Qwen3.5-122B-A10B（免费，原生VLM，10B激活，比397B更快）
# 2) NVIDIA Kimi-K2.5（免费，走 build.nvidia.com 专属 endpoint）
# 3) 硅基流动 Qwen3.5-35B-A3B（便宜付费）
# 只需填下面两个 Key；模型ID有默认值，一般不用改。
NVIDIA_API_KEY=        # nvapi-...  （同时供 1、2 使用）
SILICONFLOW_API_KEY=   # sk-...    （备用 3）

# 可选覆盖（一般不用改，默认值已配置好）
# PRIMARY_MODEL=qwen/qwen3.5-122b-a10b
# FALLBACK1_MODEL=moonshotai/kimi-k2.5
# FALLBACK1_BASE_URL=https://ai.api.nvidia.com/v1/nim/moonshotai/kimi-k2.5/v1  # Kimi 走 build 专属 endpoint
# FALLBACK2_MODEL=Qwen/Qwen3.5-35B-A3B
# 超时（秒）：免费档建议 NVIDIA >=120，硅基流动 90
# PRIMARY_TIMEOUT=120
# FALLBACK1_TIMEOUT=150
# FALLBACK2_TIMEOUT=90
PAGES=2
HEADLESS=true
